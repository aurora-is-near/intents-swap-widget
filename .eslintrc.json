{
  "root": true,
  "extends": "@aurora-is-near/eslint-config",
  "ignorePatterns": [
    "**/dist/",
    "**/coverage/",
    "**/.turbo/",
    "**/.vercel/",
    "**/node_modules/",
    "**/typings/",
    "**/scripts/",
    "**/vite.config.ts",
    "**/vitest.config.ts",
    "**/vite-env.d.ts",
    "**/postcss.config.cjs"
  ],
  "rules": {
    "@typescript-eslint/no-restricted-imports": ["error", {
        "paths": [
          {
            "name": "@material-symbols-svg/react-rounded",
            "message": "Import [icon] from @material-symbols-svg/react-rounded/icons/[icon] instead (to reduce bundle size and memory usage)",
            "allowTypeImports": true
          }
        ]
      }
    ]
  }
}
